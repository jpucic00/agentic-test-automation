# ─── Secrets ─────────────────────────────────────────────────────
# Never commit real env values. .env.example is the template.
.env
.env.local
.env.*.local
*.pem
*.key
reports/
.claude/
# Filled project-context docs hold staging credentials — NEVER commit them.
# Tracked templates: project_context.example.md / project_map.example.md.
project_context.md
project_map.md
# Exception: the bundled demo app ships its OWN filled-in context files (no real
# secrets — local demo only), so re-include them despite the name-only rules above.
!packages/demo-notes-app/project_context.md
!packages/demo-notes-app/project_map.md

# ─── Python ──────────────────────────────────────────────────────
.venv/
venv/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
*.egg-info/
build/
dist/

# ─── Node ────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Playwright (Phase 1.B+) ─────────────────────────────────────
.playwright/
# @playwright/mcp's DEFAULT output dir (page .yml snapshots, console logs), created
# in the CWD when the server runs without --output-dir — e.g. an interactive/manual
# MCP session. The pipeline itself redirects artifacts to output/snapshots/ (ignored
# below), so this only catches the default-dir case. Matches the folder anywhere.
.playwright-mcp/
playwright-report/
test-results/
storage_state*.json

# ─── Generated artifacts ─────────────────────────────────────────
# output/ holds BOTH tracked harness files (playwright.config.ts, package.json,
# package-lock.json, an empty tests/ dir) and untracked runtime artifacts. Ignore
# the runtime artifacts; keep the harness. (node_modules/, test-results/,
# playwright-report/, storage_state*.json are already ignored globally above.)
output/plans/
output/runs/
output/snapshots/*
!output/snapshots/.gitkeep
output/storage_states/
output/tests/*
!output/tests/.gitkeep
output/kb_review/

# ─── RAG / Qdrant (Phase 2.5) ────────────────────────────────────
qdrant_storage/

# ─── IDE / OS junk ───────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*.swo
