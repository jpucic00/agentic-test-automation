# ─── Secrets ─────────────────────────────────────────────────────
# Never commit real env values. .env.example is the template.
.env
.env.local
.env.*.local
*.pem
*.key

# ─── Python ──────────────────────────────────────────────────────
.venv/
venv/
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
*.egg-info/
build/
dist/

# ─── Node ────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── Playwright (Phase 1.B+) ─────────────────────────────────────
.playwright/
playwright-report/
test-results/
storage_state*.json

# ─── Generated artifacts ─────────────────────────────────────────
# output/ holds BOTH tracked harness files (playwright.config.ts, package.json,
# package-lock.json, an empty tests/ dir) and untracked runtime artifacts. Ignore
# the runtime artifacts; keep the harness. (node_modules/, test-results/,
# playwright-report/, storage_state*.json are already ignored globally above.)
output/plans/
output/runs/
output/storage_states/
output/tests/*
!output/tests/.gitkeep

# ─── RAG / Qdrant (Phase 2.5) ────────────────────────────────────
qdrant_storage/

# ─── IDE / OS junk ───────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*.swo
