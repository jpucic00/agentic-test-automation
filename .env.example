# Environment template for agentic-test-automation.
#
# Usage:
#   1. cp .env.example .env
#   2. Fill in each section below (section headers say which script consumes them).
#   3. Run scripts/step0_verify_tool_calling.py, step0b_verify_embeddings.py, step0c_xray_flavor.py.
#
# Never commit .env — it is in .gitignore. Only this template (.env.example) is tracked.

# ─── mTLS client certificate (uncomment if your gateway requires it) ─
# Most common: a single PKCS#12 bundle (.p12 OR .pfx — same format,
# different file extension) password-protected by IT. .pfx and .p12 are
# interchangeable, MTLS_PKCS12_FILE accepts either.
# MTLS_PKCS12_FILE=/absolute/path/to/client.pfx
# MTLS_PKCS12_PASSWORD=
#
# Alternative: separate PEM files for cert + key.
# MTLS_CERT_FILE=/absolute/path/to/client-cert.pem
# MTLS_KEY_FILE=/absolute/path/to/client-key.pem
# MTLS_KEY_PASSWORD=                              # only if the key is encrypted
#
# Server-side trust: only needed if the gateway/Jira/GitLab use a private CA not in
# certifi's default bundle. Most cloud-hosted gateways DON'T need this.
# SSL_CERT_FILE is read by httpx (the gateway client); REQUESTS_CA_BUNDLE is read by
# requests (the Xray + GitLab clients). Set BOTH to the same bundle when using a
# private CA. In Docker, mount the bundle read-only and point both at that path.
# SSL_CERT_FILE=/absolute/path/to/corp-ca-bundle.pem
# REQUESTS_CA_BUNDLE=/absolute/path/to/corp-ca-bundle.pem

# ─── Proxy behavior (gateway + Xray + GitLab + step0 scripts) ────
# By DEFAULT the pipeline connects DIRECTLY and IGNORES the environment's
# HTTP_PROXY / HTTPS_PROXY / NO_PROXY variables — this covers the gateway (httpx)
# AND the Xray + GitLab clients (requests). Routing the request through an
# env-configured proxy is a common cause of "server disconnected without sending
# a response" even when the TLS/mTLS handshake succeeds (a direct `curl` works;
# the same request through the proxy drops). Opt back in ONLY if your gateway/Jira
# is reachable solely through a proxy — httpx and requests then honor
# HTTP(S)_PROXY/NO_PROXY:
# USE_HTTP_PROXY=true

# ─── LLM Gateway (OpenAI-compatible) ─────────────────────────────
# Required by: scripts/step0_verify_tool_calling.py, scripts/step0b_verify_embeddings.py
LLM_BASE_URL=https://your-internal-gateway/v1   # include trailing /v1 if your gateway uses it
LLM_API_KEY=                                    # paste secret here, never commit
PLANNER_MODEL=openai/gpt-oss-120b
GENERATOR_MODEL=mistralai/devstral-small-2-2512
HEALER_MODEL=openai/gpt-oss-120b
# Optional reasoning effort for the browser agents (low | medium | high). Only meaningful
# on reasoning models (e.g. gpt-oss); never sent to the Generator. IMPORTANT: many
# OpenAI-compatible gateways silently DROP unknown request params — run
# scripts/step0d_verify_reasoning_effort.py first and only set these if it reports HONORED.
# PLANNER_REASONING_EFFORT=high
# HEALER_REASONING_EFFORT=medium

# ─── Vision sensor for the Planner (optional, OFF by default) ─────
# When PLANNER_VISION is a positive integer N, the text-only Planner gains an `inspect_screen`
# tool: it screenshots the page and asks a VISION-capable model to describe what is actually
# rendered (did a dropdown open? is a modal/overlay covering the page? did a success/error toast
# appear?) — useful when the accessibility snapshot is ambiguous. N caps the vision calls per
# planning run. `false` / `0` / unset disables it (the Planner is then identical to before).
# REQUIRES a multimodal model on your gateway (VISION_MODEL). The sensor only DESCRIBES the page —
# it never produces selectors; targeting still goes through browser_generate_locator.
# PLANNER_VISION=3
# VISION_MODEL=mistralai/devstral-small-2-2512

# ─── Embedding + Rerank (optional, for RAG) ─────
# Required by: scripts/step0b_verify_embeddings.py
# NOTE: confirm an embedding model is available on your gateway; if your app or its
# content is non-English, prefer a multilingual or matching-language variant.
EMBEDDING_MODEL=mxbai-embed-large
RERANKER_MODEL=bge-reranker-v2-m3
RERANK_ENDPOINT=                                # optional: override if /rerank lives outside /v1

# ─── Jira / Xray ─────────────────────────────────────────────────
# Required by: scripts/step0c_xray_flavor.py, src/ai_test_gen/xray_client.py, scripts/test_xray.py
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your.email@company.com               # Cloud: account email; Server/DC: username
JIRA_TOKEN=                                     # Cloud: API token from id.atlassian.com; Server/DC: PAT (sent as Bearer) or password
XRAY_IS_CLOUD=true                              # true for *.atlassian.net, false for self-hosted Jira
# Server/DC only: custom field holding the manual test steps. A common default is
# customfield_11006 ("Manual Test Steps"); find yours with
# scripts/step0c_xray_flavor.py --issue-key <KEY>. Leave unset to use the default.
# XRAY_STEPS_FIELD_ID=customfield_11006

# ─── Staging app under test ──────────────────────────────────────
# Required by: src/ai_test_gen/config.py (load_config); manual smoke check
# GUARDRAIL: STAGING_BASE_URL's host must contain a non-prod marker (see next
# section) or load_config() HARD-FAILS. The pipeline drives a real browser and
# runs generated tests against this URL — staging only, never production.
STAGING_BASE_URL=https://staging.yourapp.internal
# OPTIONAL / legacy: only scripts/save_auth_state.py (manual session capture) reads
# these. The pipeline itself logs in with the test users from project_context.md.
# STAGING_USERNAME=qa.bot
# STAGING_PASSWORD=

# ─── Production-URL guardrail (fail-closed allow-list) ───────────
# Consumed by: src/ai_test_gen/config.py (load_config)
# load_config() refuses to start unless STAGING_BASE_URL's host contains one of
# these case-insensitive substrings. Built-in defaults (no need to repeat them):
# localhost, 127.0.0.1, staging, qa, demo. If your lower environments use other
# tokens (e.g. uat, sandbox, int), list them below — comma-separated — and they
# are MERGED with the defaults. Leave unset to use the defaults only.
# NON_PROD_URL_MARKERS=uat,sandbox

# ─── GitLab (MR destination) ────────────────
# Required by: manual smoke check (curl with PRIVATE-TOKEN header)
# GITLAB_ENABLED=false runs the pipeline WITHOUT GitLab: it skips the MR step and the
# three GITLAB_* vars below are NOT required (handy for local Docker runs — the test +
# plan are still written to output/). Default true: the MR is opened and GITLAB_* must
# be set.
# GITLAB_ENABLED=true
GITLAB_BASE_URL=https://gitlab.yourcompany.internal
GITLAB_TOKEN=                                   # PAT with `api` scope, OR project access token with Developer + write_repository
GITLAB_PROJECT_ID=qa/playwright-tests           # "group/project" path or numeric ID
GITLAB_TARGET_BRANCH=main

# ─── Orchestrator ────────────────────────────────────
# Consumed by: src/ai_test_gen/orchestrator.py
# Max Healer attempts before the MR is opened for review anyway (default 2).
# MAX_HEAL_ATTEMPTS=2
# Max retries for the browser agents (Planner/Healer) when an MCP tool errors while hunting
# selectors; too low and the whole run aborts ("exceeded max retries"). Default 5.
# AGENT_MCP_RETRIES=5
# Max model requests per browser-agent run (pydantic-ai request_limit). Exploring a multi-step
# flow makes many round-trips; the library default of 50 aborts mid-run ("UsageLimitExceeded").
# Default 300; raise for very long flows, lower to cap cost.
# AGENT_REQUEST_LIMIT=300
# EXPERIMENTAL — browser-agent history trimming (DISABLED by default).
# Every MCP browser tool result embeds a full accessibility snapshot; trimming was
# built to cut that replay cost, but live runs showed mid-tier reasoning models
# losing coherence with it enabled (early give-up, skipped pages, fabricated plan
# steps). Leave both unset for normal runs; set them only for a controlled A/B.
# - SNAPSHOT_HISTORY_KEEP: set to a number to ENABLE trimming — that many newest
#   snapshots stay verbatim, the rest are stubbed.
# - ANCHOR_SNAPSHOTS (only meaningful when trimming is enabled; default on): also
#   keeps the latest snapshot of every page where a locator was captured (deduped
#   per URL + dialog-open state). off = pure newest-N window.
# SNAPSHOT_HISTORY_KEEP=2
# ANCHOR_SNAPSHOTS=on

# ─── Playwright MCP toggles (debug) ──────────────────────────────
# Consumed by: src/ai_test_gen/playwright_mcp.py
# Watch the browser drive (headed) while debugging the Planner/Healer:
# PLAYWRIGHT_MCP_HEADED=true
#
# NOT env toggles: verified-selector capture and treating the app's id= as the test id are
# committed in playwright-mcp-config.json ("capabilities": ["testing"], "testIdAttribute": "id")
# and mirrored in output/playwright.config.ts (use.testIdAttribute='id').

# ─── Test-user credentials are NOT here ──────────────────────────
# The dummy staging *user* logins that generated tests sign in with live in
# project_context.md §3 (Test users), NOT in .env — see project_context.example.md.
# Generated .spec.ts embed those disposable dummy creds directly. .env holds only
# infra secrets (gateway, Jira/Xray, GitLab, staging URL, mTLS).
